# ──────────────────────────────────────────
# Application
# ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ──────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=analysis_db
POSTGRES_PORT=5432

# ──────────────────────────────────────────
# Prisma — used by the app at runtime
# For local dev: localhost; inside Docker: postgres (service name)
# ──────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/analysis_db?schema=public"

# ──────────────────────────────────────────
# pgAdmin
# ──────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# ──────────────────────────────────────────
# JWT
# ──────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string_at_least_64_chars
JWT_REFRESH_EXPIRES_IN=7d
